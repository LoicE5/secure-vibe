# Directory to mount into the container. Use "prompt" to always be asked even if set.
# DIRECTORY=.
# DIRECTORY=prompt

# Container runtime: docker | podman
# If not set and both are available, you will be prompted at launch.
# RUNTIME=docker
# RUNTIME=prompt

# Save mode before starting: zip | copy | no
# SAVE=zip
# SAVE=prompt

# Command to run inside the container (default: Claude Code entrypoint).
# Shell metacharacters are supported (the command is wrapped in bash -c automatically).
# COMMAND=bash
# COMMAND=prompt

# Files to exclude from the container (comma-separated glob patterns).
# Matched files are physically moved out of the repo before the container starts
# and restored automatically after it exits. A warning is printed for non-gitignored files.
# EXCLUDE=.npmrc,.nvmrc,**/*.pem

# Force image rebuild (any of: true, 1, yes). Equivalent to --build.
# BUILD=true

# Force image rebuild without cache. Equivalent to --build-no-cache.
# BUILD_NO_CACHE=true
